# =============================================================================
# LabourMate — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# Generate secrets:  openssl rand -base64 32
# =============================================================================

# --- Core ---------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres) --------------------------------------------
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL uses the pooled (pgBouncer, port 6543) connection for the app.
# DIRECT_URL uses the direct (port 5432) connection for Prisma Migrate.
# connection_limit=5 lets pages that run several queries in parallel (e.g. the
# admin dashboard) share connections; raise it if you see pool timeouts.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# --- Auth.js v5 ---------------------------------------------------------------
# 32+ char secret. AUTH_URL only needed if the deploy URL differs from default.
AUTH_SECRET="<openssl rand -base64 32>"
# AUTH_URL="https://app.labourmate.co.za"

# --- PII encryption (AES-256-GCM) --------------------------------------------
# 32-byte key, base64 or hex. Encrypts ID numbers & bank details at rest.
ENCRYPTION_KEY="<openssl rand -base64 32>"

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="LabourMate <no-reply@labourmate.co.za>"

# --- Supabase (Storage / client) ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon public key>"
SUPABASE_SERVICE_ROLE_KEY="<service role key — server only>"
SUPABASE_STORAGE_BUCKET="documents"

# --- Meta WhatsApp Cloud API --------------------------------------------------
WHATSAPP_ACCESS_TOKEN="<permanent access token>"
WHATSAPP_PHONE_NUMBER_ID="<phone number id>"
WHATSAPP_BUSINESS_ACCOUNT_ID="<waba id>"
WHATSAPP_VERIFY_TOKEN="<your webhook verify token>"
WHATSAPP_API_VERSION="v21.0"

# --- Netcash Pay Now ----------------------------------------------------------
# Pay Now "service key" from Netcash → NetConnector. In the Netcash dashboard,
# set this Pay Now service's Notify/Accept URLs to your deployment, e.g.
#   Notify: {NEXT_PUBLIC_APP_URL}/api/v1/payments/netcash/notify
# LabourMate shares the TrailTime Netcash merchant account — use a dedicated
# Pay Now service for LabourMate (or point the notify URL here) so payment
# confirmations reach this app and activate subscriptions.
NETCASH_PAYNOW_SERVICE_KEY="<pay now service key>"
NETCASH_ACCOUNT_SERVICE_KEY="<account service key — optional>"
NETCASH_SOFTWARE_VENDOR_KEY="24ade73c-98cf-47b3-99be-cc7b867b3080"

# --- Scheduled jobs -----------------------------------------------------------
# Protects /api/v1/cron/* endpoints. Set the same value in your scheduler.
CRON_SECRET="<openssl rand -base64 32>"
